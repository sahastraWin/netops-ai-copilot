// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

// =============================================
// USER MODEL — Stored in MongoDB
// =============================================
model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // hashed with bcrypt
  role          Role      @default(VIEWER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  logEntries    LogEntry[]
  configs       SavedConfig[]
  auditLogs     AuditLog[]

  @@map("users")
}

enum Role {
  VIEWER        // Can view dashboards only
  JUNIOR_ENGINEER // Can generate configs, view own logs
  SENIOR_ENGINEER // Can analyze logs, generate configs
  ADMIN         // Full access including RBAC management
}

// =============================================
// AUTH.JS REQUIRED MODELS
// =============================================
model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// =============================================
// NETWORK LOG ENTRIES
// =============================================
model LogEntry {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId
  userId       String      @db.ObjectId
  rawLog       String      // Original pasted log content
  deviceType   DeviceType  @default(ROUTER)
  severity     Severity    @default(INFO)
  analysisResult String?   // AI-generated analysis
  anomalies    String[]    // List of detected anomaly types
  tags         String[]    // e.g., ["BGP", "interface-down", "security"]
  resolved     Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("log_entries")
}

enum DeviceType {
  ROUTER
  SWITCH
  FIREWALL
  ACCESS_POINT
  LOAD_BALANCER
  OTHER
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

// =============================================
// SAVED DEVICE CONFIGURATIONS
// =============================================
model SavedConfig {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  userId      String     @db.ObjectId
  title       String     // e.g., "Block 192.168.1.50 ACL"
  intent      String     // Original user intent/prompt
  generatedConfig String // The actual CLI commands
  deviceType  DeviceType @default(ROUTER)
  platform    String     @default("Cisco IOS") // e.g., "Cisco IOS", "Cisco NX-OS"
  tags        String[]
  applied     Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("saved_configs")
}

// =============================================
// AUDIT LOG — Track all sensitive actions
// =============================================
model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  action    String   // e.g., "ANALYZE_LOG", "GENERATE_CONFIG", "VIEW_CONFIGS"
  resource  String?  // ID of the resource acted on
  metadata  String?  // JSON string with extra context
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}
